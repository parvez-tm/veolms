# ---- Server ----
NODE_ENV=development
PORT=5005
# '*' (reflect any origin) or a comma-separated allowlist. Set an explicit
# allowlist in production.
CORS_ORIGIN=*
# Public URL of the frontend (used to build links in password-reset emails).
APP_URL=http://localhost:5173

# ---- Auth (JWT bearer token) ----
# Use a long, random value in any real environment.
JWT_SECRET=replace-with-a-long-random-secret
# Access-token lifetime. The client stores it and sends it as a Bearer token.
JWT_EXPIRES_IN=7d

# ---- Postgres ----
# Hosted/managed: set DATABASE_URL (and DATABASE_SSL=true for TLS).
# Local dev: leave DATABASE_URL unset and use the discrete POSTGRES_* vars.
# DATABASE_URL=postgres://user:pass@db-host:5432/veolms
DATABASE_SSL=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=veolms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---- Redis ----
REDIS_URL=redis://localhost:6379
# Cache TTL (seconds) for role permission data.
REDIS_PERMISSION_TTL=3600

# ---- Cloudflare R2 (S3-compatible) video/file storage ----
# Leave blank to disable media uploads. Video is upload-only (no external URLs),
# so with R2 unset only text lessons work.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=veolms-media
# TTL (seconds) for short-lived presigned upload/playback URLs.
R2_PLAYBACK_TTL=300

# ---- Razorpay (payments, test mode) ----
# Leave blank to disable purchases (free courses still enroll directly).
# Get test keys from the Razorpay Dashboard -> Settings -> API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Secret set on the webhook endpoint (Dashboard -> Settings -> Webhooks).
RAZORPAY_WEBHOOK_SECRET=

# ---- Email (password reset + contact form) ----
# Leave SMTP_* blank to log email links to the console (dev fallback) instead of
# sending real mail. Set all three to enable SMTP delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=VeoLMS <no-reply@veolms.local>

# ---- Seeding (runs only when the database is empty) ----
SEED_ON_START=true
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@veolms.local
ADMIN_PASSWORD=Admin@123
